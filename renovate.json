{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^README\\.md$/"],
      "matchStrings": ["v(?<currentValue>\\d+\\.\\d+\\.\\d+)-dockertag"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/kloudkit/workspace",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Group bjw-s common chart across all charts",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["common"],
      "groupName": "bjw-s common chart"
    }
  ]
}
